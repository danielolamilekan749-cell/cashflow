# Nomba Sandbox credentials (from hackathon email or Nomba Dashboard → Developer → API Keys)
# Docs: https://developer.nomba.com/docs/getting-started/get-api-keys
#
# Use sandbox credentials with VITE_NOMBA_ENV=sandbox during Onboarding Week.
# Never commit real .env files or production keys to git.

VITE_NOMBA_ENV=sandbox
VITE_NOMBA_CLIENT_ID=your_sandbox_client_id
VITE_NOMBA_CLIENT_SECRET=your_sandbox_client_secret
VITE_NOMBA_ACCOUNT_ID=your_sandbox_account_id
